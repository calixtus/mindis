<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<SplitPane fx:id="root" xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.mindis.gui.services.ServicesController"
           dividerPositions="0.5">
    <VBox spacing="8">
        <padding>
            <Insets top="12" right="12" bottom="12" left="12"/>
        </padding>
        <TableView fx:id="servicesTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="dateColumn" text="%Date" prefWidth="140"/>
                <TableColumn fx:id="typeColumn" text="%Type" prefWidth="120"/>
                <TableColumn fx:id="locationColumn" text="%Location" prefWidth="120"/>
                <TableColumn fx:id="slotsColumn" text="%Required servers" prefWidth="130"/>
            </columns>
        </TableView>
        <HBox spacing="8">
            <Button text="%New" onAction="#onNewService"/>
            <Button text="%Delete" onAction="#onDeleteService"/>
        </HBox>
        <TitledPane text="%Generate from templates" collapsible="false">
            <HBox spacing="8">
                <padding>
                    <Insets top="8" right="8" bottom="8" left="8"/>
                </padding>
                <DatePicker fx:id="generateFromPicker" promptText="%From"/>
                <DatePicker fx:id="generateToPicker" promptText="%To"/>
                <Button text="%Generate" onAction="#onGenerate"/>
            </HBox>
        </TitledPane>
    </VBox>

    <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="edge-to-edge"
                hbarPolicy="NEVER">
    <VBox spacing="10" minHeight="520">
        <padding>
            <Insets top="12" right="12" bottom="12" left="12"/>
        </padding>
        <GridPane hgap="8" vgap="8">
            <columnConstraints>
                <ColumnConstraints minWidth="110"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>
            <Label text="%Date" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <DatePicker fx:id="serviceDatePicker" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Label text="%Time" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="serviceTimeField" promptText="10:00" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            <Label text="%Type" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <ComboBox fx:id="serviceTypeBox" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            <Label text="%Location" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="serviceLocationField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            <Label text="%Note" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <TextField fx:id="serviceNoteField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            <Label fx:id="slotsLabel" text="%Required servers" alignment="CENTER_LEFT"
                   GridPane.rowIndex="5" GridPane.columnIndex="0" GridPane.valignment="TOP"/>
            <ScrollPane styleClass="edge-to-edge" fitToWidth="true" prefHeight="200"
                        GridPane.rowIndex="5" GridPane.columnIndex="1" GridPane.vgrow="ALWAYS">
                <VBox fx:id="slotsList" spacing="8"/>
            </ScrollPane>
        </GridPane>

        <HBox spacing="8">
            <Button text="%Save" onAction="#onSaveService" defaultButton="true"/>
        </HBox>

        <TitledPane text="%Weekly templates" collapsible="false">
            <VBox spacing="8">
                <padding>
                    <Insets top="8" right="8" bottom="8" left="8"/>
                </padding>
                <TableView fx:id="templatesTable" prefHeight="140">
                    <columns>
                        <TableColumn fx:id="templateDayColumn" text="%Weekday" prefWidth="110"/>
                        <TableColumn fx:id="templateTimeColumn" text="%Time" prefWidth="70"/>
                        <TableColumn fx:id="templateTypeColumn" text="%Type" prefWidth="110"/>
                        <TableColumn fx:id="templateLocationColumn" text="%Location" prefWidth="110"/>
                    </columns>
                </TableView>
                <HBox spacing="8">
                    <ComboBox fx:id="templateDayBox"/>
                    <TextField fx:id="templateTimeField" promptText="10:00" prefWidth="70"/>
                    <ComboBox fx:id="templateTypeBox"/>
                    <TextField fx:id="templateLocationField" promptText="%Location" HBox.hgrow="ALWAYS"/>
                </HBox>
                <HBox spacing="8">
                    <Button text="%Add" onAction="#onAddTemplate"/>
                    <Button text="%Remove" onAction="#onRemoveTemplate"/>
                </HBox>
            </VBox>
        </TitledPane>
    </VBox>
    </ScrollPane>
</SplitPane>
