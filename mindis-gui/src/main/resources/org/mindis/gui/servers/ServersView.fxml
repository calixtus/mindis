<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<SplitPane fx:id="root" xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.mindis.gui.servers.ServersController"
           dividerPositions="0.45">
    <VBox spacing="8">
        <padding>
            <Insets top="12" right="12" bottom="12" left="12"/>
        </padding>
        <TableView fx:id="serversTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="nameColumn" text="%Name" prefWidth="180"/>
                <TableColumn fx:id="qualificationsColumn" text="%Qualifications" prefWidth="160"/>
                <TableColumn fx:id="activeColumn" text="%Active" prefWidth="60"/>
            </columns>
        </TableView>
        <HBox spacing="8">
            <Button fx:id="newButton" text="%New" onAction="#onNew"/>
            <Button fx:id="deleteButton" text="%Delete" onAction="#onDelete"/>
        </HBox>
    </VBox>

    <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="edge-to-edge"
                hbarPolicy="NEVER">
    <VBox spacing="10" minHeight="520">
        <padding>
            <Insets top="12" right="12" bottom="12" left="12"/>
        </padding>
        <GridPane hgap="8" vgap="8" VBox.vgrow="ALWAYS">
            <columnConstraints>
                <ColumnConstraints minWidth="110"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>
            <Label text="%First name" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="firstNameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Label text="%Last name" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="lastNameField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            <Label text="%Contact" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="contactField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            <Label text="%Birth date" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <DatePicker fx:id="birthDatePicker" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            <Label text="%Family" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <TextField fx:id="familyIdField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
            <Label text="%Preferred times" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <TextField fx:id="preferredTimesField" promptText="10:00, 18:30"
                       GridPane.rowIndex="5" GridPane.columnIndex="1"/>
            <Label text="%Experienced" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
            <CheckBox fx:id="experiencedCheck" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
            <Label text="%Active" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
            <CheckBox fx:id="activeCheck" GridPane.rowIndex="7" GridPane.columnIndex="1"/>

            <Label text="%Qualifications" GridPane.rowIndex="8" GridPane.columnIndex="0"
                   GridPane.valignment="TOP"/>
            <ListView fx:id="qualificationsList" prefHeight="150"
                      GridPane.rowIndex="8" GridPane.columnIndex="1" GridPane.vgrow="ALWAYS"/>

            <Label text="%Unavailable periods" GridPane.rowIndex="9" GridPane.columnIndex="0"
                   GridPane.valignment="TOP"/>
            <VBox spacing="8" GridPane.rowIndex="9" GridPane.columnIndex="1" GridPane.vgrow="ALWAYS">
                <ListView fx:id="unavailabilityList" prefHeight="110" VBox.vgrow="ALWAYS"/>
                <HBox spacing="8">
                    <DatePicker fx:id="periodFromPicker" promptText="%From"/>
                    <DatePicker fx:id="periodToPicker" promptText="%To"/>
                    <Button text="%Add" onAction="#onAddPeriod"/>
                    <Button text="%Remove" onAction="#onRemovePeriod"/>
                </HBox>
            </VBox>
        </GridPane>

        <HBox spacing="8">
            <Button fx:id="saveButton" text="%Save" onAction="#onSave" defaultButton="true"/>
        </HBox>
    </VBox>
    </ScrollPane>
</SplitPane>
